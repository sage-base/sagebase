#!/bin/bash

# Pre-ExitPlanMode hook - Codex CLIでplanファイルをレビューしてからplan modeを終了する
#
# 動作:
# 1. tmp/ 配下の最新 .md ファイルをplanファイルとして検出
# 2. Codex CLI (codex exec) でレビューを実行
# 3. レビュー結果を additionalContext として Claude に返す
# 4. ExitPlanMode は allow（レビュー結果は参考情報として提供）

set -euo pipefail

# stdin から JSON を読み取る
json_input=$(cat)

# 作業ディレクトリを特定（worktree対応）
# stdinのJSONにcwdフィールドがある場合はそちらを優先（worktree環境で正しいパスを使用するため）
HOOK_CWD=$(echo "$json_input" | python3 -c 'import json,sys; d=json.load(sys.stdin); print(d.get("cwd",""))' 2>/dev/null || true)
if [ -n "$HOOK_CWD" ] && [ -d "$HOOK_CWD" ]; then
    PROJECT_ROOT="$HOOK_CWD"
else
    PROJECT_ROOT="${CLAUDE_PROJECT_DIR:-$(cd "$(dirname "$0")/../.." && pwd)}"
fi

# レビュー済みマーカーファイル（同一planファイルの再レビューを防止）
REVIEW_MARKER="$PROJECT_ROOT/tmp/.codex_review_done"

# 既にレビュー済みの場合はスキップ（無限ループ防止）
if [ -f "$REVIEW_MARKER" ]; then
    # マーカーを削除（次回のplan作成時にはレビューが走るように）
    rm -f "$REVIEW_MARKER"
    python3 -c '
import json, sys
json.dump({
    "decision": "approve",
    "hookSpecificOutput": {
        "hookEventName": "PreToolUse",
        "additionalContext": "✅ Codexレビューは前回実施済みです。追加レビューなしでplan modeを終了します。"
    }
}, sys.stdout)
'
    exit 0
fi

# tmp/ ディレクトリの存在チェック
if [ ! -d "$PROJECT_ROOT/tmp" ]; then
    python3 -c '
import json, sys
json.dump({
    "decision": "approve",
    "hookSpecificOutput": {
        "hookEventName": "PreToolUse",
        "additionalContext": "⚠️ tmp/ ディレクトリが存在しません。planファイルの検出をスキップしました。"
    }
}, sys.stdout)
'
    exit 0
fi

# tmp/ 配下の最新 .md ファイルを検出
PLAN_FILE=$(ls -t "$PROJECT_ROOT/tmp/"*.md 2>/dev/null | head -1 || true)

if [ -z "$PLAN_FILE" ]; then
    python3 -c '
import json, sys
json.dump({
    "decision": "approve",
    "hookSpecificOutput": {
        "hookEventName": "PreToolUse",
        "additionalContext": "⚠️ tmp/ ディレクトリにplanファイル(.md)が見つかりませんでした。Codexレビューをスキップします。"
    }
}, sys.stdout)
'
    exit 0
fi

PLAN_FILENAME=$(basename "$PLAN_FILE")

# Codex CLI でレビューを実行
# プロンプトを構築して stdin 経由で渡す
CODEX_REVIEW=$(
{
    cat <<'PROMPT_HEADER'
以下の実装計画をレビューしてください。
問題点、改善提案、リスクを日本語で簡潔にまとめてください。

レビュー観点:
1. 実装手順の妥当性と完全性
2. 技術的リスクや考慮漏れ
3. 既存アーキテクチャとの整合性
4. テスト戦略の十分性

簡潔に箇条書きでレビュー結果を出力してください。
問題がなければ「問題なし」と明記してください。

---
実装計画:
PROMPT_HEADER
    cat "$PLAN_FILE"
} | (cd "$PROJECT_ROOT" && codex exec -) 2>&1
) || true

CODEX_EXIT=${PIPESTATUS[0]:-$?}

# Python で JSON を安全に生成して出力
export PLAN_FILENAME
export CODEX_REVIEW
export CODEX_EXIT
export REVIEW_MARKER

python3 -c '
import json, sys, os

plan_filename = os.environ.get("PLAN_FILENAME", "unknown")
codex_review = os.environ.get("CODEX_REVIEW", "")
codex_exit = int(os.environ.get("CODEX_EXIT", "1"))

if codex_exit != 0 or not codex_review.strip():
    context = (
        f"⚠️ Codexレビューの実行に失敗しました (exit: {codex_exit})\n\n"
        f"planファイル: {plan_filename}\n\n"
        f"Codex出力:\n{codex_review}\n\n"
        "Codexレビューなしでplan modeを終了します。"
    )
else:
    # レビュー済みマーカーを作成（次回ExitPlanModeで再レビューしない）
    review_marker = os.environ.get("REVIEW_MARKER", "")
    if review_marker:
        try:
            with open(review_marker, "w") as f:
                f.write(plan_filename)
        except OSError:
            pass

    context = (
        f"## 📋 Codex Plan Review\n\n"
        f"planファイル: {plan_filename}\n\n"
        f"### レビュー結果\n\n"
        f"{codex_review}\n\n"
        "---\n"
        "上記はCodex CLIによるplanファイルのレビュー結果です（参考情報）。\n"
        "**重要**: 以下の基準で対応を判断してください:\n"
        "- 🔴 重大な問題（ロジックの誤り、アーキテクチャ違反、セキュリティリスク）→ planファイルに反映\n"
        "- 🟡 軽微な改善提案（文言修正、フォーマット、好みの差異レベル）→ 無視してOK\n"
        "- 🟢「問題なし」→ そのままplan modeを終了\n\n"
        "軽微な指摘しかない場合は、修正せずそのままExitPlanModeしてください。\n"
        "このレビューは1回のみ実施されます（再exit時にはスキップされます）。"
    )

output = {
    "decision": "approve",
    "hookSpecificOutput": {
        "hookEventName": "PreToolUse",
        "additionalContext": context
    }
}
json.dump(output, sys.stdout)
'

exit 0
